# --- PocketBase Configuration ---
# 12-Factor: The URL where the PocketBase backend is running
PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090

# --- Admin Credentials (Used for migrations/setup) ---
PB_ADMIN_EMAIL=admin@yt-manager.com
PB_ADMIN_PASSWORD=admin123456

# --- Web/Edge Mode Configuration ---
# 12-Factor: URL for the Edge API when not running in Tauri
PUBLIC_EDGE_BACKEND_URL=https://api.yt-manager.com

# --- YouTube API Configuration ---
# 12-Factor: Credentials from Google Cloud Console
YOUTUBE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your_client_secret_here
YOUTUBE_REDIRECT_URI=http://localhost:1420

# --- Optional Features ---
# ENABLE_ANALYTICS=false
# LOG_LEVEL=info
